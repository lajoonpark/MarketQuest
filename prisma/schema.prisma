generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  id              String    @id @default(uuid())
  userId          String    @unique @map("user_id")
  username        String    @unique
  displayName     String    @map("display_name")
  avatarUrl       String?   @map("avatar_url")
  xp              Int       @default(0)
  level           Int       @default(1)
  currentStreak   Int       @default(0) @map("current_streak")
  longestStreak   Int       @default(0) @map("longest_streak")
  lastLoginDate   DateTime? @map("last_login_date")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  portfolios         Portfolio[]
  userQuests         UserQuest[]
  userAchievements   UserAchievement[]
  leaderboardEntries LeaderboardSnapshot[]
  userLessonProgress UserLessonProgress[]

  @@map("profiles")
}

model Company {
  id             String   @id @default(uuid())
  name           String
  ticker         String   @unique
  sector         String
  description    String
  currentPrice   Decimal  @map("current_price") @db.Decimal(10, 2)
  previousPrice  Decimal  @map("previous_price") @db.Decimal(10, 2)
  volatility     Decimal  @db.Decimal(4, 3)
  growthRating   Int      @map("growth_rating")
  riskRating     Int      @map("risk_rating")
  sentimentScore Decimal  @map("sentiment_score") @db.Decimal(4, 3)
  logoSvg        String   @map("logo_svg")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  priceHistory CompanyPriceHistory[]
  news         MarketNews[]
  holdings     Holding[]
  trades       Trade[]

  @@map("companies")
}

model CompanyPriceHistory {
  id         String   @id @default(uuid())
  companyId  String   @map("company_id")
  price      Decimal  @db.Decimal(10, 2)
  recordedAt DateTime @default(now()) @map("recorded_at")

  company Company @relation(fields: [companyId], references: [id])

  @@map("company_price_history")
}

model MarketNews {
  id                String   @id @default(uuid())
  title             String
  description       String
  affectedCompanyId String?  @map("affected_company_id")
  affectedSector    String?  @map("affected_sector")
  impactDirection   String   @map("impact_direction")
  impactStrength    Decimal  @map("impact_strength") @db.Decimal(4, 3)
  createdAt         DateTime @default(now()) @map("created_at")
  expiresAt         DateTime @map("expires_at")

  company Company? @relation(fields: [affectedCompanyId], references: [id])

  @@map("market_news")
}

model Season {
  id           String   @id @default(uuid())
  name         String
  startDate    DateTime @map("start_date")
  endDate      DateTime @map("end_date")
  startingCash Decimal  @map("starting_cash") @db.Decimal(10, 2)
  status       String   @default("active")
  createdAt    DateTime @default(now()) @map("created_at")

  portfolios         Portfolio[]
  leaderboardEntries LeaderboardSnapshot[]

  @@map("seasons")
}

model Portfolio {
  id        String   @id @default(uuid())
  profileId String   @map("profile_id")
  seasonId  String   @map("season_id")
  cash      Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profile  Profile  @relation(fields: [profileId], references: [id])
  season   Season   @relation(fields: [seasonId], references: [id])
  holdings Holding[]
  trades   Trade[]

  @@unique([profileId, seasonId])
  @@map("portfolios")
}

model Holding {
  id            String   @id @default(uuid())
  portfolioId   String   @map("portfolio_id")
  companyId     String   @map("company_id")
  shares        Decimal  @db.Decimal(15, 6)
  avgBuyPrice   Decimal  @map("avg_buy_price") @db.Decimal(10, 2)
  totalInvested Decimal  @map("total_invested") @db.Decimal(10, 2)
  realizedPnl   Decimal  @default(0) @map("realized_pnl") @db.Decimal(10, 2)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  portfolio Portfolio @relation(fields: [portfolioId], references: [id])
  company   Company   @relation(fields: [companyId], references: [id])

  @@unique([portfolioId, companyId])
  @@map("holdings")
}

model Trade {
  id          String   @id @default(uuid())
  portfolioId String   @map("portfolio_id")
  companyId   String   @map("company_id")
  type        String
  shares      Decimal  @db.Decimal(15, 6)
  price       Decimal  @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now()) @map("created_at")

  portfolio Portfolio @relation(fields: [portfolioId], references: [id])
  company   Company   @relation(fields: [companyId], references: [id])

  @@map("trades")
}

model Quest {
  id          String @id @default(uuid())
  title       String
  description String
  type        String
  target      Int
  xpReward    Int    @map("xp_reward")
  icon        String

  userQuests UserQuest[]

  @@map("quests")
}

model UserQuest {
  id         String    @id @default(uuid())
  profileId  String    @map("profile_id")
  questId    String    @map("quest_id")
  progress   Int       @default(0)
  completed  Boolean   @default(false)
  claimedAt  DateTime? @map("claimed_at")
  assignedAt DateTime  @default(now()) @map("assigned_at")

  profile Profile @relation(fields: [profileId], references: [id])
  quest   Quest   @relation(fields: [questId], references: [id])

  @@map("user_quests")
}

model Achievement {
  id          String @id @default(uuid())
  title       String
  description String
  icon        String
  xpReward    Int    @map("xp_reward")

  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(uuid())
  profileId     String   @map("profile_id")
  achievementId String   @map("achievement_id")
  unlockedAt    DateTime @default(now()) @map("unlocked_at")

  profile     Profile     @relation(fields: [profileId], references: [id])
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([profileId, achievementId])
  @@map("user_achievements")
}

model LeaderboardSnapshot {
  id             String   @id @default(uuid())
  profileId      String   @map("profile_id")
  seasonId       String   @map("season_id")
  rank           Int
  portfolioValue Decimal  @map("portfolio_value") @db.Decimal(10, 2)
  returnPct      Decimal  @map("return_pct") @db.Decimal(8, 4)
  snapshotAt     DateTime @default(now()) @map("snapshot_at")

  profile Profile @relation(fields: [profileId], references: [id])
  season  Season  @relation(fields: [seasonId], references: [id])

  @@map("leaderboard_snapshots")
}

model Lesson {
  id         String @id @default(uuid())
  title      String
  slug       String @unique
  content    String
  xpReward   Int    @map("xp_reward")
  orderIndex Int    @map("order_index")

  userProgress UserLessonProgress[]

  @@map("lessons")
}

model UserLessonProgress {
  id          String   @id @default(uuid())
  profileId   String   @map("profile_id")
  lessonId    String   @map("lesson_id")
  completedAt DateTime @default(now()) @map("completed_at")

  profile Profile @relation(fields: [profileId], references: [id])
  lesson  Lesson  @relation(fields: [lessonId], references: [id])

  @@unique([profileId, lessonId])
  @@map("user_lesson_progress")
}
